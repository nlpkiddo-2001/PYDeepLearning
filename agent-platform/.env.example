# Environment variables for AgentForge
# Copy this file to .env and fill in your values

# LLM Provider API Keys
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Custom LLM endpoint (Ollama / vLLM)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# CUSTOM_LLM_URL=http://localhost:8080/v1

# AgentForge API auth (optional)
AGENTFORGE_API_KEY=your-api-key-here

# Memory
CHROMA_PERSIST_DIR=./data/chroma_store
SQLITE_DB_PATH=./data/memory.db
